<div class="space-y-2 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "Já tem conta? Entrar", new_session_path(resource_name), class: "text-stone-600 hover:text-stone-900" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p><%= link_to "Criar cadastro", new_registration_path(resource_name), class: "text-stone-600 hover:text-stone-900" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "text-stone-600 hover:text-stone-900" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "Não recebeu instruções de confirmação?", new_confirmation_path(resource_name), class: "text-stone-600 hover:text-stone-900" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to "Não recebeu instruções de desbloqueio?", new_unlock_path(resource_name), class: "text-stone-600 hover:text-stone-900" %></p>
  <% end %>
</div>
