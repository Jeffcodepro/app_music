<!-- This controller initializes the DS25 3D hovers and parallax effects -->
<div data-controller="design-system">
  <div class="grain"></div>

  <!-- Background Orbs -->
  <div class="orb w-[600px] h-[600px] bg-accent-blue top-[-10%] left-[-5%]" id="orb-1"></div>
  <div class="orb w-[500px] h-[500px] bg-accent-glow bottom-[10%] right-[-5%]" id="orb-2"></div>

  <!-- Navigation (Floating Pill style) -->
  <% login_path = respond_to?(:new_user_session_path) ? new_user_session_path : "#cta" %>
  <% cadastro_path = respond_to?(:new_user_registration_path) ? new_user_registration_path : "#planos" %>
  <nav class="fixed top-8 left-1/2 -translate-x-1/2 z-[100] w-[94%] lg:w-auto">
      <div class="glass-static px-5 lg:px-6 py-3.5 lg:py-4 rounded-full flex items-center justify-between gap-4 lg:gap-8 border border-white/40">
          <a href="#hero" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 rounded-full bg-stone-900 flex items-center justify-center text-white">
                  <i data-lucide="play" class="w-4 h-4 ml-0.5"></i>
              </div>
              <span class="font-bold tracking-tighter text-lg">AppMusic</span>
          </a>

          <div class="hidden lg:flex items-center gap-6 text-[10px] uppercase tracking-[0.2em] font-bold text-stone-600">
              <a href="#vantagens" class="hover:text-stone-900 transition-colors">Vantagens</a>
              <a href="#conteudo" class="hover:text-stone-900 transition-colors">Conteúdo</a>
              <a href="#planos" class="hover:text-stone-900 transition-colors">Planos</a>
              <a href="#faq" class="hover:text-stone-900 transition-colors">Dúvidas</a>
          </div>

          <div class="flex items-center gap-2">
              <a href="<%= login_path %>" class="px-4 py-2 rounded-full text-[10px] uppercase tracking-widest font-bold text-stone-700 border border-stone-300/80 hover:text-stone-900 hover:border-stone-400 transition-colors">
                  Login
              </a>
              <a href="<%= cadastro_path %>" class="bg-stone-900 text-white px-4 lg:px-6 py-2 rounded-full text-[10px] uppercase tracking-widest font-bold hover:bg-stone-800 transition-colors">
                  Cadastro
              </a>
          </div>
      </div>
  </nav>

  <section id="hero" class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-[#0A0A0A]" data-controller="seamless-loop">

    <!-- Vídeo Primário -->
    <%= video_tag "Sheet_music_looping_motion_graphic_delpmaspu.mp4",
                  data: { seamless_loop_target: "primary" },
                  class: "absolute inset-0 w-full h-full object-cover scale-105 video-layer video-primary",
                  muted: true,
                  playsinline: true,
                  preload: "auto" %>

    <!-- Vídeo Secundário (Escondido e preparado) -->
    <%= video_tag "Sheet_music_looping_motion_graphic_delpmaspu.mp4",
                  data: { seamless_loop_target: "secondary" },
                  class: "absolute inset-0 w-full h-full object-cover scale-105 video-layer video-secondary",
                  muted: true,
                  playsinline: true,
                  preload: "auto" %>

    <!-- Gradientes de sombreamento para dar o tom Cinematográfico -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/90 z-20 pointer-events-none"></div>

    <!-- O Conteúdo Frontal (Estilo DS25) -->
    <div class="relative z-30 text-center px-6 max-w-5xl mx-auto flex flex-col items-center">

      <div class="reveal mb-8">
        <span class="px-4 py-2 border border-white/20 rounded-full text-white/70 text-[10px] uppercase tracking-widest font-bold backdrop-blur-md inline-block">
          Ensino Musical Premium
        </span>
      </div>

      <h1 class="transparent-text-layer hero-title-font text-[clamp(2.8rem,8vw,6.5rem)] font-black leading-[0.95] tracking-[-0.02em] uppercase">
        <span class="text-reveal-wrapper active block">
            <span class="text-reveal-content">Teoria Musical</span>
        </span>
        <span class="text-reveal-wrapper active block mt-1">
            <span class="text-reveal-content text-transparent bg-clip-text bg-gradient-to-r from-white via-stone-400 to-white" style="transition-delay: 0.2s;">No Ponto Certo</span>
        </span>
      </h1>

      <p class="reveal text-lg font-light text-stone-300 max-w-3xl mx-auto mt-8 leading-relaxed" style="transition-delay: 0.4s;">
        Vídeo aulas, trilhas personalizadas, exercícios interativos, modo carreira e experiências em grupo para transformar teoria em prática de verdade.
      </p>

      <div class="reveal mt-12 flex flex-col sm:flex-row gap-6 items-center" style="transition-delay: 0.6s;">
        <a href="#planos" class="btn-beam inline-block">
            <button class="btn-beam-content bg-stone-900 border border-white/20 hover:bg-stone-800">
                <span class="font-bold">Começar grátis</span>
                <i data-lucide="arrow-right" class="w-4 h-4 ml-2"></i>
            </button>
        </a>
        <a href="#como-funciona" class="text-white/70 hover:text-white transition-colors flex items-center gap-2 text-sm uppercase tracking-widest font-bold">
            Ver como funciona
            <i data-lucide="chevron-down" class="w-4 h-4"></i>
        </a>
      </div>

    </div>
  </section>

  <!-- 2. DIFERENCIAIS (Bento Grid) -->
  <section id="vantagens" class="relative z-30 py-32 px-8 max-w-[1400px] mx-auto bg-grid bg-white border-t border-stone-100 mt-0">
      <div class="mb-24 reveal text-center max-w-4xl mx-auto flex flex-col items-center">
          <div class="w-12 h-12 rounded-full border border-stone-200 flex items-center justify-center mb-6 shadow-sm"><i data-lucide="sparkles" class="w-5 h-5 text-stone-900"></i></div>
          <h2 class="text-5xl md:text-6xl font-medium tracking-tighter mb-8 tabular-nums">Muito além de assistir aulas</h2>
          <p class="text-stone-500 font-light text-xl leading-relaxed">
              A plataforma foi criada para ajudar você a entender música com <span class="font-bold text-stone-900">clareza</span>, praticar com <span class="font-bold text-stone-900">constância</span> e evoluir de forma real.
          </p>
      </div>

      <!-- Creative Music-Themed Grid Layout -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                  <!-- Card 1: Nivelamento Inteligente (The Tuning Fork / Metronome) -->
          <div class="reveal border border-stone-200 bg-stone-50 p-10 rounded-[40px] hover:-translate-y-2 hover:shadow-xl transition-all relative overflow-hidden group flex flex-col justify-between" style="transition-delay: 0.1s;">
              <!-- Metronome pendulum abstraction -->
              <div class="absolute top-[-10%] right-10 w-2 h-32 bg-stone-200 rounded-full origin-top transform rotate-12 group-hover:-rotate-12 transition-transform duration-1000 ease-in-out">
                  <div class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-8 h-8 rounded-full border-4 border-stone-300 bg-stone-100"></div>
              </div>

              <div class="relative z-10 w-14 h-14 rounded-full bg-white border border-stone-200 flex items-center justify-center mb-12 shadow-sm text-stone-900 group-hover:bg-stone-900 group-hover:text-white transition-colors duration-500">
                  <i data-lucide="music-4" class="w-6 h-6"></i>
              </div>
              <div class="relative z-10">
                  <h4 class="text-2xl font-bold mb-3">Nivelamento inteligente</h4>
                  <p class="text-stone-500 font-light text-base leading-relaxed">Descubra seu nível em leitura, ritmo, percepção e harmonia.</p>
              </div>
          </div>

          <!-- Card 2: Trilha personalizada (The Conductor / Sheet Music) -->
          <div class="reveal lg:col-span-2 border border-stone-200 bg-stone-900 text-white p-12 rounded-[40px] hover:shadow-2xl transition-all relative overflow-hidden group min-h-[320px]">
              <!-- Animated Stave Background -->
              <div class="absolute inset-0 opacity-10 flex flex-col justify-center gap-4 group-hover:opacity-20 transition-opacity duration-1000 -rotate-3 scale-110">
                  <div class="w-full h-[1px] bg-white"></div>
                  <div class="w-full h-[1px] bg-white"></div>
                  <div class="w-full h-[1px] bg-white"></div>
                  <div class="w-full h-[1px] bg-white"></div>
                  <div class="w-full h-[1px] bg-white"></div>
              </div>
              <div class="absolute right-0 top-0 bottom-0 w-1/2 bg-gradient-to-l from-stone-900 to-transparent z-10"></div>

              <div class="relative z-20 h-full flex flex-col justify-between max-w-lg">
                  <div class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-md border border-white/5 text-white mb-6">
                      <i data-lucide="list-music" class="w-8 h-8"></i>
                  </div>
                  <div>
                      <h4 class="text-3xl font-bold mb-4">Trilha personalizada</h4>
                      <p class="text-stone-300 font-light text-lg leading-relaxed">Receba um caminho de estudo organizado com base no que você já sabe e no que precisa desenvolver.</p>
                  </div>
              </div>
          </div>

          <!-- Divisória removida para evitar conflito com o diff -->

          <!-- Card 3: Prática recorrente (The Vinyl Loop) -->
          <div class="reveal border border-stone-200 bg-white p-10 rounded-[40px] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all relative overflow-hidden group flex flex-col justify-end min-h-[300px]" style="transition-delay: 0.2s;">
              <!-- Spinning Vinyl Decoration -->
              <div class="absolute -top-16 -right-16 w-48 h-48 bg-stone-900 rounded-full border-8 border-stone-800 shadow-2xl flex items-center justify-center group-hover:rotate-180 transition-transform duration-[2s] ease-linear">
                  <!-- Grooves -->
                  <div class="w-40 h-40 rounded-full border border-stone-700 opacity-50 flex items-center justify-center">
                      <div class="w-32 h-32 rounded-full border border-stone-700 opacity-50 flex items-center justify-center">
                          <div class="w-24 h-24 rounded-full border border-stone-700 opacity-50 flex items-center justify-center">
                              <!-- Label -->
                              <div class="w-16 h-16 rounded-full bg-stone-100 flex items-center justify-center">
                                  <div class="w-2 h-2 rounded-full bg-stone-900"></div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>

              <div class="relative z-10 mt-20">
                  <div class="flex items-center gap-3 mb-3">
                      <i data-lucide="mic-2" class="w-6 h-6 text-stone-900"></i>
                      <h4 class="text-xl font-bold">Prática recorrente</h4>
                  </div>
                  <p class="text-stone-500 font-light text-sm leading-relaxed">Exercícios por aula, playgrounds automáticos e revisões para fixar o conteúdo.</p>
              </div>
          </div>

          <!-- Card 4: Evolução visível (The Equalizer) -->
          <div class="reveal border border-stone-200 bg-[#F9F9F8] p-12 rounded-[40px] hover:shadow-xl hover:bg-[#F9F9F8] transition-all relative overflow-hidden flex flex-col justify-between group group/eq min-h-[300px]" style="transition-delay: 0.3s;">
             <!-- Animated Equalizer Bars (Background Layer) -->
             <div class="absolute lg:top-12 right-0 bottom-0 w-32 flex items-end justify-between gap-1 pb-0 opacity-20 group-hover:opacity-100 transition-opacity duration-500 z-0">
                 <div class="w-full bg-stone-900/10 rounded-t-sm h-[20%] group-hover/eq:h-[80%] transition-all duration-700 ease-in-out"></div>
                 <div class="w-full bg-stone-900/10 rounded-t-sm h-[40%] group-hover/eq:h-[60%] transition-all duration-500 ease-in-out delay-75"></div>
                 <div class="w-full bg-stone-900/20 rounded-t-sm h-[30%] group-hover/eq:h-[90%] transition-all duration-1000 ease-in-out delay-150"></div>
                 <div class="w-full bg-stone-900/30 rounded-t-sm h-[60%] group-hover/eq:h-[40%] transition-all duration-300 ease-in-out delay-75"></div>
                 <div class="w-full bg-stone-900/40 rounded-t-sm h-[10%] group-hover/eq:h-[100%] transition-all duration-700 ease-in-out delay-200"></div>
             </div>

             <!-- Text Content (Foreground Layer) -->
             <div class="relative z-10 w-16 h-16 rounded-full bg-white border border-stone-100 shadow-sm flex items-center justify-center mb-6 text-stone-900">
                  <i data-lucide="bar-chart-2" class="w-8 h-8"></i>
              </div>
             <div class="relative z-10 max-w-[200px] bg-[#F9F9F8]/60 backdrop-blur-sm p-2 -ml-2 rounded-xl">
                  <h4 class="text-2xl font-bold mb-3">Evolução visível</h4>
                  <p class="text-stone-500 font-light text-sm leading-relaxed">Acompanhe seu progresso, suba de nível e avance com segurança.</p>
              </div>
          </div>

          <!-- Card 5: Diversão em grupo -->
          <div class="reveal border border-stone-200 bg-stone-50 p-10 rounded-[40px] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all flex flex-col justify-between group" style="transition-delay: 0.4s;">
              <i data-lucide="users" class="w-10 h-10 text-stone-900 mb-6 opacity-40 group-hover:opacity-100 transition-opacity"></i>
              <div>
                  <h4 class="text-xl font-bold mb-3">Diversão em grupo</h4>
                  <p class="text-stone-500 font-light text-sm leading-relaxed">Participe de experiências ao vivo com perguntas e ranking em tempo real.</p>
              </div>
          </div>
      </div>
  </section>

  <!-- 3. PROBLEMA + SOLUÇÃO -->
  <section id="problema" class="py-32 bg-stone-900 text-white relative border-t border-white/10">
      <div class="absolute inset-0 bg-grid opacity-5"></div>

      <div class="max-w-[1200px] mx-auto px-8 relative z-10">
          <div class="flex flex-col md:flex-row gap-20 items-center">

              <div class="w-full md:w-1/2 reveal">
                  <h2 class="text-5xl font-medium tracking-tighter mb-8 tabular-nums">Estudar música não deveria ser confuso</h2>

                  <div class="space-y-6 text-stone-400 font-light text-lg leading-relaxed">
                      <p>Muita gente começa teoria musical e encontra conteúdo solto, explicações difíceis e pouca prática real.</p>

                      <p>Aqui, você não precisa adivinhar por onde começar. A plataforma identifica seu nível, organiza sua jornada e combina <strong class="text-white font-medium">explicação, prática e progressão</strong> em uma experiência muito mais clara.</p>
                  </div>
              </div>

              <div class="w-full md:w-1/2 reveal glass-static sound-wave-card p-12 rounded-[50px] bg-white/5 border border-white/10 flex items-center justify-center min-h-[400px]" style="transition-delay: 0.2s;">
                  <div class="relative w-full h-full flex items-center justify-center">
                      <!-- Wave layers -->
                      <div class="absolute w-44 h-44 border border-white/20 rounded-full sound-wave-ring wave-delay-1"></div>
                      <div class="absolute w-32 h-32 border border-white/30 rounded-full sound-wave-ring wave-delay-2"></div>
                      <div class="absolute w-44 h-44 border border-white/20 rounded-full animate-[spin_10s_linear_infinite] border-dashed"></div>
                      <div class="absolute w-32 h-32 border border-white/20 rounded-full animate-[spin_7s_linear_infinite_reverse]"></div>
                      <div class="absolute w-20 h-20 bg-stone-800 rounded-full sound-wave-core flex items-center justify-center shadow-[0_0_50px_rgba(255,255,255,0.1)]">
                          <i data-lucide="music" class="w-8 h-8 text-white"></i>
                      </div>
                  </div>
              </div>

          </div>
      </div>
  </section>

  <!-- 4. COMO FUNCIONA (5 Steps) -->
  <section id="como-funciona" class="py-32 bg-stone-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-10"></div>

      <div class="max-w-[1400px] mx-auto px-8 relative z-10">
          <div class="flex flex-col mb-20 reveal">
              <h2 class="text-5xl font-medium tracking-tighter mb-6">Uma jornada feita para o seu momento</h2>
          </div>

          <!-- 5 steps list/grid -->
          <div class="space-y-4 scroll-steps" data-scroll-steps>
              <div class="step-card border border-white/10 bg-white/5 p-8 rounded-3xl flex flex-col md:flex-row gap-8 items-start md:items-center">
                  <div class="text-6xl font-black text-white/10 italic">1</div>
                  <div>
                      <h4 class="text-2xl font-bold mb-2">Comece do zero ou faça seu nivelamento</h4>
                      <p class="text-stone-400 font-light text-sm">Escolha iniciar pelos fundamentos ou descobrir seu nível em cada área.</p>
                  </div>
              </div>

              <div class="step-card border border-white/10 bg-white/5 p-8 rounded-3xl flex flex-col md:flex-row gap-8 items-start md:items-center">
                  <div class="text-6xl font-black text-white/10 italic">2</div>
                  <div>
                      <h4 class="text-2xl font-bold mb-2">Receba sua trilha personalizada</h4>
                      <p class="text-stone-400 font-light text-sm">A plataforma organiza seu estudo em leitura, ritmo, percepção e harmonia.</p>
                  </div>
              </div>

              <div class="step-card border border-white/10 bg-white/5 p-8 rounded-3xl flex flex-col md:flex-row gap-8 items-start md:items-center">
                  <div class="text-6xl font-black text-white/10 italic">3</div>
                  <div>
                      <h4 class="text-2xl font-bold mb-2">Estude do seu jeito</h4>
                      <p class="text-stone-400 font-light text-sm">Use o modo guiado ou o modo livre, conforme a forma como você aprende melhor.</p>
                  </div>
              </div>

              <div class="step-card border border-white/10 bg-white/5 p-8 rounded-3xl flex flex-col md:flex-row gap-8 items-start md:items-center">
                  <div class="text-6xl font-black text-white/10 italic">4</div>
                  <div>
                      <h4 class="text-2xl font-bold mb-2">Pratique de verdade</h4>
                      <p class="text-stone-400 font-light text-sm">Resolva exercícios, treine nos playgrounds e revise o que precisa melhorar.</p>
                  </div>
              </div>

              <div class="step-card border border-white/10 bg-white/5 p-8 rounded-3xl flex flex-col md:flex-row gap-8 items-start md:items-center">
                  <div class="text-6xl font-black text-white/10 italic">5</div>
                  <div>
                      <h4 class="text-2xl font-bold mb-2">Acompanhe sua evolução</h4>
                      <p class="text-stone-400 font-light text-sm">Suba no modo carreira, complete missões e veja seu progresso com clareza.</p>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- 5. MODOS DE ESTUDO -->
  <section id="modos-estudo" class="py-32 bg-stone-50 border-t border-stone-200">
      <div class="max-w-[1400px] mx-auto px-8">
          <div class="mb-20 reveal text-center max-w-4xl mx-auto">
              <h2 class="text-5xl md:text-6xl font-medium tracking-tighter mb-8 tabular-nums">Dois modos de aprender, um só objetivo: fazer você evoluir</h2>
              <p class="text-stone-500 font-light text-lg md:text-[1.45rem]">
                  Porque cada aluno aprende de um jeito — e uma boa plataforma precisa respeitar isso.
              </p>
          </div>

          <div class="study-modes-shell flex flex-col md:flex-row gap-6 reveal">
              <div class="study-mode-card study-mode-divider w-full md:w-1/2 p-10 md:p-12 flex flex-col justify-between">
                  <div>
                      <div class="study-mode-icon study-mode-icon--dark">
                          <i data-lucide="mic" class="w-5 h-5"></i>
                      </div>
                      <h3 class="text-3xl font-bold mb-4">Modo guiado</h3>
                      <p class="text-stone-500 font-light leading-relaxed text-xl max-w-[520px]">
                          Para quem gosta de estudar com acompanhamento, pausas estratégicas e prática ao longo da aula.
                      </p>
                  </div>
              </div>

              <div class="study-mode-card w-full md:w-1/2 p-10 md:p-12 flex flex-col justify-between" style="transition-delay: 0.1s;">
                  <div>
                      <div class="study-mode-icon text-stone-900">
                          <i data-lucide="key" class="w-5 h-5"></i>
                      </div>
                      <h3 class="text-3xl font-bold mb-4">Modo livre</h3>
                      <p class="text-stone-700 font-light leading-relaxed text-xl max-w-[520px]">
                          Para quem prefere assistir no próprio ritmo, revisar com calma e praticar depois.
                      </p>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- 6. PLAYGROUNDS -->
  <section id="playgrounds" class="py-32 relative bg-[linear-gradient(180deg,#ffffff_0%,#fafaf9_100%)]">
      <div class="max-w-[1400px] mx-auto px-8">
          <div class="mb-20 reveal grid grid-cols-1 lg:grid-cols-2 gap-12 items-end">
              <div>
                  <h2 class="text-[clamp(2.3rem,4.2vw,4rem)] font-medium tracking-tighter leading-[1.03]">Treine quantas vezes precisar</h2>
              </div>
              <div>
                  <p class="text-stone-500 font-light text-lg leading-relaxed">
                      Os playgrounds transformam teoria em prática com exercícios gerados automaticamente por tema, dificuldade e objetivo. Em vez de repetir sempre os mesmos exemplos, você pratica com novas variações e desenvolve domínio real.
                  </p>
              </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
              <article class="reveal flash-card group relative h-[20.5rem] rounded-[30px] p-8 bg-stone-950 text-white border border-stone-800/80 flex flex-col">
                  <div class="mb-10 w-14 h-14 rounded-2xl bg-white/10 border border-white/15 flex items-center justify-center">
                      <i data-lucide="book-open" class="w-6 h-6 text-white"></i>
                  </div>
                  <h4 class="text-[1.9rem] font-semibold tracking-tight mb-3">Leitura</h4>
                  <p class="text-sm font-light leading-relaxed text-stone-300 max-w-[20ch]">
                      Notas, claves, figuras e reconhecimento visual.
                  </p>
                  <div class="mt-auto pt-6 border-t border-white/10 flex items-end gap-1.5">
                      <span class="h-2 w-7 rounded-full bg-white/35"></span>
                      <span class="h-2 w-11 rounded-full bg-white/60"></span>
                      <span class="h-2 w-5 rounded-full bg-white"></span>
                  </div>
              </article>

              <article class="reveal flash-card group relative h-[20.5rem] rounded-[30px] p-8 bg-white border border-stone-200 text-stone-900 flex flex-col" style="transition-delay: 0.1s;">
                  <div class="mb-10 w-14 h-14 rounded-2xl bg-stone-100 border border-stone-200 flex items-center justify-center">
                      <i data-lucide="activity" class="w-6 h-6 text-stone-900"></i>
                  </div>
                  <h4 class="text-[1.9rem] font-semibold tracking-tight mb-3">Ritmo</h4>
                  <p class="text-sm font-light leading-relaxed text-stone-500 max-w-[24ch]">
                      Pulsação, subdivisão, compassos e padrões rítmicos.
                  </p>
                  <div class="mt-auto pt-6 border-t border-stone-200 grid grid-cols-6 gap-1.5">
                      <span class="h-1.5 rounded-full bg-stone-300"></span>
                      <span class="h-1.5 rounded-full bg-stone-900"></span>
                      <span class="h-1.5 rounded-full bg-stone-300"></span>
                      <span class="h-1.5 rounded-full bg-stone-900"></span>
                      <span class="h-1.5 rounded-full bg-stone-300"></span>
                      <span class="h-1.5 rounded-full bg-stone-900"></span>
                  </div>
              </article>

              <article class="reveal flash-card group relative h-[20.5rem] rounded-[30px] p-8 bg-white border border-stone-200 text-stone-900 flex flex-col" style="transition-delay: 0.2s;">
                  <div class="mb-10 w-14 h-14 rounded-2xl bg-stone-100 border border-stone-200 flex items-center justify-center">
