<!DOCTYPE html>
<html>
  <head>
    <title>AppMusic</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Inter", "sans-serif"],
              mono: ["JetBrains Mono", "monospace"]
            }
          }
        }
      }
    </script>
  </head>

  <body class="app-body">
    <%= render "shared/flash" %>

    <div class="app-shell" data-controller="app-shell" data-app-shell-storage-key-value="app_music_sidebar_collapsed">
      <%= render "platform/side_nav" %>

      <div class="app-workspace">
        <%= render "platform/top_nav" %>
        <main class="app-main">
          <%= yield %>
        </main>
      </div>
    </div>

    <script>
      document.addEventListener("turbo:load", function() {
        if (typeof lucide !== "undefined") lucide.createIcons();
      });
    </script>
  </body>
</html>
