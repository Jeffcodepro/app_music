<section class="platform-shell">
  <div class="platform-container">
    <h1 class="platform-title">Nivelamento inicial</h1>

    <article class="platform-card">
      <h2>Diagnóstico musical</h2>
      <p>Etapa para identificar seu ponto atual em leitura, rítmica, percepção e harmonia.</p>
      <ul class="platform-list">
        <li>Bloco 1: Estruturação / Leitura</li>
        <li>Bloco 2: Rítmica</li>
        <li>Bloco 3: Percepção</li>
        <li>Bloco 4: Harmonia</li>
      </ul>
      <div class="platform-actions">
        <%= link_to "Iniciar nivelamento", app_trilhas_path, class: "app-btn app-btn--primary" %>
      </div>
    </article>
  </div>
</section>
