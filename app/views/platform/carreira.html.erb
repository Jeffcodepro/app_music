<section class="platform-shell">
  <div class="platform-container">
    <h1 class="platform-title">Modo carreira</h1>

    <div class="platform-grid">
      <article class="platform-card">
        <h2>Progressão</h2>
        <p>XP, níveis, checkpoints e marcos de desenvolvimento.</p>
        <div class="platform-actions">
          <%= link_to "Ver desafios", app_arena_path, class: "app-btn" %>
        </div>
      </article>
      <article class="platform-card">
        <h2>Desafios</h2>
        <p>Metas semanais e missões para consistência de estudo.</p>
      </article>
      <article class="platform-card">
        <h2>Rankings</h2>
        <p>Evolução comparativa por categoria e temporadas.</p>
      </article>
    </div>
  </div>
</section>
