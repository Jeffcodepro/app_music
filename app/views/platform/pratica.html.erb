<section class="platform-shell">
  <div class="platform-container">
    <% mode = params[:mode].presence || "livre" %>
    <% area = params[:area].presence || "geral" %>
    <h1 class="platform-title">Prática e playgrounds</h1>

    <article class="platform-card">
      <h2>Laboratório de prática</h2>
      <p>Exercícios gerados por tema, dificuldade e objetivo.</p>
      <p class="muted">Modo: <strong><%= mode.capitalize %></strong> | Área: <strong><%= area.capitalize %></strong></p>
      <ul class="platform-list">
        <li>Playground de leitura</li>
        <li>Playground de rítmica</li>
        <li>Playground de percepção</li>
        <li>Playground de harmonia</li>
      </ul>
      <div class="platform-actions">
        <%= link_to "Concluir sessão e voltar ao dashboard", app_dashboard_path, class: "app-btn app-btn--primary" %>
      </div>
    </article>
  </div>
</section>
