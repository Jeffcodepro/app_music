<section class="platform-shell">
  <div class="platform-container platform-container--narrow">
    <h1 class="platform-title">Escolha do objetivo</h1>
    <article class="platform-card">
      <%= form_with url: update_onboarding_objective_path, method: :patch, class: "space-y-3" do |f| %>
        <% options = [
          "aprender teoria do zero",
          "melhorar leitura",
          "treinar percepção",
          "desenvolver ritmo",
          "aprofundar harmonia",
          "estudar de forma guiada",
          "estudar no próprio ritmo"
        ] %>
        <% options.each do |option| %>
          <label class="platform-option">
            <%= f.radio_button :objective, option, checked: session[:onboarding_objective] == option %>
            <span><%= option.capitalize %></span>
          </label>
        <% end %>
        <div class="pt-4">
          <%= f.submit "Continuar", class: "app-btn app-btn--primary" %>
        </div>
      <% end %>
    </article>
  </div>
</section>
