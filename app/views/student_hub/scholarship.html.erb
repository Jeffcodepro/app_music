<section class="platform-shell">
  <div class="platform-container">
    <h1 class="platform-title">Bolsa de Evolução</h1>

    <article class="platform-card">
      <h2>Desconto por progresso real</h2>
      <p>Fluxo para upgrade com recompensa baseada em desempenho.</p>
      <ul class="platform-list">
        <li>Conclusão da trilha recomendada</li>
        <li>Média mínima de acerto</li>
        <li>Checkpoint no modo carreira</li>
        <li>Consistência mínima</li>
      </ul>
      <p class="muted">Faixas previstas: Progresso, Destaque e Excelência.</p>
      <div class="platform-actions">
        <%= link_to "Ver comparação de planos", app_plans_compare_path, class: "app-btn app-btn--primary" %>
      </div>
    </article>
  </div>
</section>
