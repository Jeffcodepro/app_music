<%= turbo_frame_tag "perception_playground" do %>
  <article class="platform-card playground-stage"
           data-controller="interval-player preferences"
           data-interval-player-first-frequency-value="<%= perception_exercise[:reference_frequency] %>"
           data-interval-player-second-frequency-value="<%= perception_exercise[:target_frequency] %>"
           data-interval-player-first-pitch-value="<%= perception_exercise[:reference_pitch] %>"
           data-interval-player-second-pitch-value="<%= perception_exercise[:target_pitch] %>"
           data-interval-player-auto-play-value="<%= perception_autoplay ? 'true' : 'false' %>"
           data-interval-player-instrument-value="<%= perception_exercise[:instrument] %>">
    <% answered = playground_feedback.present? %>
    <% answered_correctly = playground_feedback&.dig(:correct) %>
    <% answered_incorrectly = answered && !answered_correctly %>
    <div class="playground-stage__header">
      <div>
        <p class="playground-eyebrow">Modo ativo</p>
        <h2>Playground de percepção</h2>
        <p>Ouça duas notas consecutivas e identifique o intervalo melódico. Agora você pode escolher o instrumento sintetizado e travar a direção da pergunta em crescente, decrescente ou misto.</p>
      </div>
    </div>

    <% if playground_feedback.present? %>
      <div class="playground-feedback <%= playground_feedback[:correct] ? 'is-correct' : 'is-incorrect' %>" data-interval-player-target="feedback">
        <p class="playground-eyebrow">Última resposta</p>
        <% if playground_feedback[:correct] %>
          <h3>Resposta correta</h3>
          <p>Você acertou com <strong><%= playground_feedback[:selected_label] %></strong>.</p>
          <p class="muted">Rodada: <strong><%= playground_feedback[:direction_label] %></strong> | Notas sorteadas: <strong><%= playground_feedback[:notes] %></strong></p>
        <% else %>
          <h3>Você errou este intervalo</h3>
          <p>Se quiser tentar novamente, repita o áudio ou avance para o próximo intervalo.</p>
        <% end %>
      </div>
    <% end %>

    <div class="playground-scoreboard">
      <div class="playground-scoreboard__item is-correct">
        <span class="playground-scoreboard__label">Acertos</span>
        <strong><%= perception_scoreboard[:correct_count] %></strong>
      </div>
      <div class="playground-scoreboard__item is-incorrect">
        <span class="playground-scoreboard__label">Erros</span>
        <strong><%= perception_scoreboard[:incorrect_count] %></strong>
      </div>
    </div>

    <%= form_with url: app_playground_path, method: :get, class: "playground-controls playground-controls--stacked", data: { turbo_frame: "perception_playground", preferences_target: "form" } do %>
      <%= hidden_field_tag :activity, "percepcao" %>

      <div class="playground-control">
        <span class="playground-control__label">Instrumento</span>
        <div class="playground-option-grid">
          <% perception_instruments.each do |instrument| %>
            <% checked = perception_preferences[:instrument] == instrument[:id] %>
            <label class="playground-select-card <%= 'is-selected' if checked %>">
              <%= radio_button_tag :instrument, instrument[:id], checked, class: "playground-select-card__input", data: { action: "change->preferences#submit" } %>
              <span class="playground-select-card__icon"><%= instrument_option_icon(instrument[:id]) %></span>
              <span class="playground-select-card__body">
                <span class="playground-select-card__title"><%= instrument[:label] %></span>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="playground-control">
        <span class="playground-control__label">Direção do intervalo</span>
        <div class="playground-direction-grid">
          <% perception_direction_modes.each do |mode| %>
            <% checked = perception_preferences[:direction_mode] == mode[:id] %>
            <label class="playground-direction-card <%= 'is-selected' if checked %>">
              <%= radio_button_tag :direction_mode, mode[:id], checked, class: "playground-direction-card__input", data: { action: "change->preferences#submit" } %>
              <span class="playground-direction-card__title"><%= mode[:label] %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="playground-stage__grid">
      <div class="playground-trainer">
        <p class="playground-eyebrow">Rodada atual</p>
        <h3>Identifique o intervalo melódico</h3>
        <p><%= perception_exercise[:question] %></p>
        <div class="playground-player-controls">
          <button type="button"
                  class="playground-player-button"
                  data-action="interval-player#repeat"
                  aria-label="Repetir intervalo">
            <span class="app-btn__icon"><%= interface_symbol_icon("restart") %></span>
          </button>

          <% if answered_correctly %>
            <%= link_to app_playground_path(activity: "percepcao", refresh: 1, autoplay: 1, **perception_preferences),
                        class: "playground-player-button playground-player-button--primary",
                        data: { turbo_frame: "perception_playground" },
                        aria: { label: "Próximo intervalo e tocar" } do %>
              <span class="app-btn__icon"><%= interface_symbol_icon("play") %></span>
            <% end %>
          <% else %>
            <button type="button"
                    class="playground-player-button playground-player-button--primary"
                    data-action="interval-player#play"
                    data-interval-player-target="trigger"
                    aria-label="Tocar intervalo"
                    <%= "disabled" if answered_incorrectly %>>
              <span class="app-btn__icon"><%= interface_symbol_icon("play") %></span>
            </button>
          <% end %>

          <%= link_to app_playground_path(activity: "percepcao", refresh: 1, **perception_preferences),
                      class: "playground-player-button",
                      data: { turbo_frame: "perception_playground" },
                      aria: { label: "Próximo intervalo" } do %>
            <span class="app-btn__icon"><%= interface_symbol_icon("next") %></span>
          <% end %>
        </div>
      </div>

      <div class="playground-response-panel">
        <p class="playground-eyebrow">Resposta</p>
        <h3>Escolha a opção correta</h3>
        <div class="perception-options">
          <% perception_exercise[:options].each do |option| %>
            <%= button_to submit_app_playground_answer_path,
                          method: :post,
                          params: {
                            activity: "percepcao",
                            selected_option_id: option[:id],
                            instrument: perception_preferences[:instrument],
                            direction_mode: perception_preferences[:direction_mode]
                          },
                          class: "perception-option",
                          disabled: answered_correctly,
                          form: { data: { turbo_frame: "perception_playground" } } do %>
              <span class="perception-option__label"><%= option[:label] %></span>
              <span class="perception-option__meta">
                <%= if answered_correctly
                      "Rodada encerrada"
                    elsif answered_incorrectly
                      "Tentar novamente"
                    else
                      "Tentar esta resposta"
                    end %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </article>
<% end %>
