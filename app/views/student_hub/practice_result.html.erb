<section class="platform-shell">
  <div class="platform-container platform-container--narrow">
    <h1 class="platform-title">Resultado da prática</h1>

    <article class="platform-card">
      <h2>Resumo da sessão</h2>
      <p>Acertos, erros, explicações e recomendação de revisão curta.</p>
      <ul class="platform-list">
        <li>Acertos: 16</li>
        <li>Erros: 4</li>
        <li>Tema recomendado para revisão: Percepção de intervalos</li>
      </ul>
      <div class="platform-actions">
        <%= link_to "Revisar aula relacionada", app_aulas_path, class: "app-btn" %>
        <%= link_to "Abrir playground sugerido", app_playground_path, class: "app-btn app-btn--primary" %>
      </div>
    </article>
  </div>
</section>
